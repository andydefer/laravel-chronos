{
    "name": "andydefer/laravel-chronos",
    "description": "Clean and flexible scheduling for Laravel applications.",
    "autoload": {
        "psr-4": {
            "AndyDefer\\LaravelChronos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\LaravelChronos\\Tests\\": "tests/"
        }
    },
    "keywords": [
        "laravel",
        "laravel-package",
        "scheduler",
        "scheduling",
        "availability",
        "bookings",
        "appointments",
        "time-slots",
        "shifts",
        "roster",
        "calendar",
        "Eloquent",
        "traits",
        "PHP",
        "open-source"
    ],
    "extra": {
        "laravel": {
            "providers": [
                "AndyDefer\\LaravelHermes\\Providers\\LaravelChronosServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^12.0|^13.0|^14.0|^15.0",
        "andydefer/laravel-task": "^4.9.11"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29"
    }
}
